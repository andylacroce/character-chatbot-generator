{
  "name": "character-chatbot-generator",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "ci": "npm run lint -- --max-warnings=0 && npm run lint:md && npm run type-check && npm run test:coverage && npm run build",
    "vercel-build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:md": "markdownlint --config .markdownlint.json \"**/*.md\" --ignore \"node_modules/**\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --silent --coverageReporters=text --coverageReporters=text-summary",
    "type-check": "tsc --noEmit",
    "postinstall": "node ./scripts/fix-express-tsconfig.cjs",
    "type-check:watch": "tsc --noEmit --watch",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google-cloud/aiplatform": "^6.8.1",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@trendmicro/react-toggle-switch": "^0.5.7",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.6.0",
    "@vercel/speed-insights": "^2.0.0",
    "critters": "^0.0.25",
    "express-rate-limit": "^8.5.2",
    "lru-cache": "^11.5.2",
    "next": "^16.2.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-window": "^2.2.7",
    "sanitize-filename": "^1.6.3",
    "uuid": "^14.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^8.0.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@typescript-eslint/type-utils": "^8.62.1",
    "@typescript-eslint/typescript-estree": "^8.62.1",
    "@typescript-eslint/utils": "^8.63.0",
    "autoprefixer": "^10.5.2",
    "babel-jest": "^30.4.1",
    "baseline-browser-mapping": "^2.10.42",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "express": "^5.2.1",
    "ipinfo": "^1.5.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "markdownlint-cli": "^0.49.0",
    "node-mocks-http": "^1.18.0",
    "postcss": "^8.5.15",
    "typescript": "^6"
  },
  "overrides": {
    "undici": "^6.23.0",
    "postcss": "^8.5.15",
    "js-yaml": "^4.3.0"
  }
}
